# Copy to .env and fill in your key
GEMINI_API_KEY=your_google_gemini_api_key_here

# Optional overrides
# gemini-2.5-flash-lite has a higher free-tier daily limit (good for dev);
# gemini-2.5-flash gives the best label OCR quality (good for production).
GEMINI_MODEL=gemini-2.5-flash-lite
# Fallback models tried in order if the primary is overloaded (503) or rate-limited (429).
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (SQLite by default; use a postgresql:// URL in production)
DATABASE_URL=sqlite:///./nutriscan.db
# Auth — CHANGE THIS to a long random string in production
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080
